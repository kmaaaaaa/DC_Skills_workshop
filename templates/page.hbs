<!doctype html>
<html lang="{{page.lang}}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{page.title}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700&family=Noto+Serif+JP:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#F4F1EA;
    --bg-2:#FBF9F4;
    --paper:#FFFFFF;
    --ink:#1B1A17;
    --ink-2:#3C3A34;
    --ink-3:#75716A;
    --line:#E4DFD3;
    --line-2:#D9D3C4;
    --accent:#C8643C;     /* Claude burnt orange */
    --accent-2:#A14F2C;
    --accent-soft:#F6E3D6;
    --leaf:#5C6B3F;
    --serif:"Noto Serif JP", "Hiragino Mincho ProN", serif;
    --sans:"Noto Sans JP", "Hiragino Kaku Gothic ProN", system-ui, sans-serif;
    --mono:"JetBrains Mono", ui-monospace, monospace;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:var(--sans);font-feature-settings:"palt";-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  body{font-size:16px;line-height:1.75;letter-spacing:.01em}
  a{color:inherit}
  ::selection{background:var(--accent);color:#fff}

  /* layout */
  .wrap{max-width:1180px;margin:0 auto;padding:0 32px}
  @media (max-width:900px){.wrap{padding:0 20px}}
  section{padding:120px 0;border-top:1px solid var(--line)}
  section:first-of-type{border-top:none}

  /* nav */
  .nav{position:sticky;top:0;z-index:50;background:rgba(244,241,234,.85);backdrop-filter:saturate(180%) blur(14px);border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 64px;font-size:13.5px}
  @media (max-width:900px){.nav-inner{padding:14px 24px}}
  .brand{display:flex;align-items:center;gap:10px;font-weight:600;letter-spacing:.04em}
  .brand-mark{width:22px;height:22px;border-radius:6px;background:var(--accent);display:grid;place-items:center;color:#fff}
  .nav-links{display:flex;gap:28px;color:var(--ink-2)}
  .nav-links a{text-decoration:none}
  .nav-links a:hover{color:var(--accent)}
  @media (max-width:760px){.nav-links{display:none}}

  /* hero */
  .hero{padding:120px 0 100px}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:10px}
  .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
  h1.display{font-family:var(--serif);font-weight:500;font-size:clamp(40px,5.6vw,76px);line-height:1.12;letter-spacing:-.005em;margin:28px 0 24px;color:var(--ink);text-wrap:balance}
  h1.display em{font-style:normal;color:var(--accent)}
  .lede{font-size:19px;line-height:1.85;color:var(--ink-2);max-width:780px;text-wrap:pretty}
  .hero-meta{display:flex;flex-wrap:wrap;gap:28px;margin-top:48px;color:var(--ink-3);font-size:13px;font-family:var(--mono);letter-spacing:.04em}
  .hero-meta span{display:inline-flex;align-items:center;gap:8px}

  /* hero figure */
  .hero-figure{margin-top:80px;border:1px solid var(--line);background:var(--paper);border-radius:18px;padding:44px;display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .hero-figure > div{padding:0 28px;border-right:1px solid var(--line)}
  .hero-figure > div:last-child{border-right:none}
  .hero-figure .k{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--ink-3);text-transform:uppercase;margin-bottom:14px}
  .hero-figure .v{font-family:var(--serif);font-size:48px;line-height:1;color:var(--ink);font-weight:500}
  .hero-figure .v .u{font-family:var(--sans);font-size:18px;color:var(--ink-2);margin-left:6px;font-weight:400}
  .hero-figure .c{font-size:13px;color:var(--ink-3);margin-top:10px;line-height:1.6}
  @media (max-width:900px){.hero-figure{grid-template-columns:repeat(2,1fr);gap:24px}.hero-figure > div{border-right:none;border-bottom:1px solid var(--line);padding-bottom:24px}.hero-figure > div:nth-last-child(-n+2){border-bottom:none;padding-bottom:0}}

  /* section heading */
  .sec-head{display:grid;grid-template-columns:auto 1fr;gap:32px;align-items:flex-start;margin-bottom:64px;padding-bottom:32px;border-bottom:1px solid var(--line)}
  .sec-num{font-family:var(--mono);font-size:13px;color:var(--accent);letter-spacing:.16em;padding-top:14px}
  .sec-icon{width:56px;height:56px;border:1px solid var(--line-2);border-radius:14px;display:grid;place-items:center;background:var(--bg-2);color:var(--ink)}
  .sec-title-block{display:flex;flex-direction:column;gap:8px}
  h2.sec{font-family:var(--serif);font-weight:500;font-size:44px;line-height:1.25;margin:0;letter-spacing:-.005em;text-wrap:balance}
  .sec-sub{color:var(--ink-3);font-size:15px}
  .sec-head-left{display:flex;gap:24px;align-items:center}

  /* body type */
  h3{font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.4;margin:48px 0 16px;letter-spacing:-.002em}
  h4{font-size:15px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--accent-2);margin:32px 0 12px;font-family:var(--mono)}
  p{margin:0 0 16px;color:var(--ink-2);text-wrap:pretty}
  strong{font-weight:600;color:var(--ink);background:linear-gradient(transparent 65%, var(--accent-soft) 65%)}

  /* callout / pull quote */
  .pull{display:grid;grid-template-columns:auto 1fr;gap:24px;padding:36px 40px;background:var(--paper);border:1px solid var(--line);border-radius:14px;margin:36px 0}
  .pull .qmark{font-family:var(--serif);font-size:72px;line-height:.8;color:var(--accent);font-style:italic}
  .pull p{margin:0;font-family:var(--serif);font-size:21px;line-height:1.65;color:var(--ink)}
  .pull cite{display:block;margin-top:14px;font-style:normal;font-family:var(--mono);font-size:12px;color:var(--ink-3);letter-spacing:.1em;text-transform:uppercase}

  /* big stat row */
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:40px 0}
  .stat{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:32px;display:flex;flex-direction:column}
  .stat .org{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--ink-3);text-transform:uppercase;margin-bottom:18px;display:flex;align-items:center;gap:10px}
  .stat .org .pill{display:inline-flex;width:24px;height:24px;border-radius:7px;background:var(--accent-soft);color:var(--accent-2);align-items:center;justify-content:center}
  .stat .row{display:flex;align-items:baseline;gap:12px;margin-bottom:6px;flex-wrap:nowrap;white-space:nowrap}
  .stat .a{font-family:var(--serif);font-size:22px;color:var(--ink-3);text-decoration:line-through;text-decoration-color:var(--ink-3);font-weight:400;white-space:nowrap}
  .stat .arrow{color:var(--accent);flex-shrink:0}
  .stat .b{font-family:var(--serif);font-size:30px;color:var(--accent);font-weight:500;line-height:1;white-space:nowrap}
  .stat .label{color:var(--ink-2);font-size:14px;line-height:1.6;margin-top:18px;padding-top:14px;border-top:1px solid var(--line)}
  @media (max-width:900px){.stats{grid-template-columns:1fr}}

  /* table */
  table{width:100%;border-collapse:separate;border-spacing:0;font-size:14.5px;background:var(--paper);border:1px solid var(--line);border-radius:14px;overflow:hidden;margin:32px 0}
  th,td{padding:18px 22px;text-align:left;vertical-align:top;border-bottom:1px solid var(--line)}
  thead th{background:var(--bg-2);font-family:var(--mono);font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);font-weight:500}
  tbody tr:last-child td{border-bottom:none}
  td.key{font-weight:600;color:var(--ink);width:200px;font-family:var(--serif);font-size:17px}
  .table-cap{font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.14em;text-transform:uppercase;margin:48px 0 12px}

  /* progressive disclosure 3-layer figure */
  .layers{display:flex;flex-direction:column;gap:14px;margin:36px 0}
  .layer{display:grid;grid-template-columns:80px 1fr auto;align-items:stretch;background:var(--paper);border:1px solid var(--line);border-radius:14px;overflow:hidden}
  .layer .l-num{background:var(--accent-soft);color:var(--accent-2);display:grid;place-items:center;font-family:var(--mono);font-size:13px;letter-spacing:.12em;font-weight:500}
  .layer .l-body{padding:22px 28px}
  .layer .l-body h5{font-family:var(--serif);font-weight:500;font-size:20px;margin:0 0 4px}
  .layer .l-body p{margin:0;font-size:14.5px;max-width:none}
  .layer .l-side{display:grid;place-items:center;padding:0 28px;color:var(--ink-3);font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;border-left:1px dashed var(--line-2);min-width:140px;text-align:center;line-height:1.5}

  /* kitchen analogy */
  .kitchen{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:36px 0}
  .kit{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:32px}
  .kit .head{display:flex;align-items:center;gap:14px;margin-bottom:20px}
  .kit .head .ico{width:44px;height:44px;border-radius:11px;background:var(--accent-soft);color:var(--accent-2);display:grid;place-items:center}
  .kit .head h5{font-family:var(--serif);font-size:22px;font-weight:500;margin:0}
  .kit .head .tag{margin-left:auto;font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.12em;text-transform:uppercase}
  .kit p{margin:0;font-size:14.5px;color:var(--ink-2)}
  @media (max-width:900px){.kitchen{grid-template-columns:1fr}}

  /* warning */
  .warn{border:1px solid var(--line-2);background:var(--bg-2);border-radius:14px;padding:28px 32px;margin:36px 0;display:grid;grid-template-columns:auto 1fr;gap:20px;align-items:flex-start}
  .warn .ico{width:40px;height:40px;border-radius:10px;background:var(--ink);color:var(--bg);display:grid;place-items:center;flex-shrink:0}
  .warn h5{margin:0 0 10px;font-family:var(--serif);font-size:18px;font-weight:500}
  .warn ul{margin:0;padding-left:18px;font-size:14.5px;color:var(--ink-2)}
  .warn li{margin:4px 0}
  .warn code{font-family:var(--mono);font-size:13px;color:var(--accent-2);background:var(--accent-soft);padding:1px 6px;border-radius:4px}

  /* category cards */
  .cats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:36px 0}
  .cat{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:32px;display:flex;flex-direction:column;gap:14px;min-height:240px}
  .cat .ico{width:48px;height:48px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:grid;place-items:center}
  .cat h5{font-family:var(--serif);font-size:20px;font-weight:500;margin:0}
  .cat p{margin:0;font-size:14px;line-height:1.7}
  .cat .ex{font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.08em;margin-top:auto;padding-top:14px;border-top:1px dashed var(--line-2)}
  @media (max-width:900px){.cats{grid-template-columns:1fr}}

  /* priority matrix */
  .matrix{margin:48px 0 24px;display:grid;grid-template-columns:60px 1fr;gap:0}
  .matrix .y-label{writing-mode:vertical-rl;transform:rotate(180deg);font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--ink-3);text-transform:uppercase;display:grid;place-items:center;border-right:1px dashed var(--line-2)}
  .matrix .grid{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:14px;overflow:hidden}
  .matrix .cell{background:var(--paper);padding:24px 26px;min-height:160px;display:flex;flex-direction:column;gap:8px}
  .matrix .cell.hi{background:var(--accent-soft)}
  .matrix .cell .lvl{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--ink-3);text-transform:uppercase}
  .matrix .cell.hi .lvl{color:var(--accent-2)}
  .matrix .cell h5{font-family:var(--serif);font-size:18px;font-weight:500;margin:0}
  .matrix .cell p{margin:0;font-size:13.5px;line-height:1.65}
  .matrix .x-label{margin-top:14px;display:grid;grid-template-columns:60px 1fr 1fr;align-items:center}
  .matrix .x-label > div{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--ink-3);text-transform:uppercase;text-align:center}
  .matrix .x-label > div:nth-child(1){text-align:left}

  /* 4-step process */
  .steps{display:grid;grid-auto-flow:column;grid-auto-columns:1fr;gap:0;margin:40px 0;border:1px solid var(--line);border-radius:14px;overflow:hidden;background:var(--paper)}
  .step{padding:32px;border-right:1px solid var(--line);position:relative}
  .step:last-child{border-right:none}
  .step .n{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--accent);text-transform:uppercase;margin-bottom:18px}
  .step .ico{width:44px;height:44px;border:1px solid var(--line-2);border-radius:11px;display:grid;place-items:center;margin-bottom:18px;background:var(--bg-2)}
  .step h5{font-family:var(--serif);font-size:19px;font-weight:500;margin:0 0 8px}
  .step p{margin:0;font-size:13.5px;line-height:1.65}
  .step::after{content:"";position:absolute;right:-7px;top:50%;width:14px;height:14px;background:var(--paper);border-top:1px solid var(--line);border-right:1px solid var(--line);transform:translateY(-50%) rotate(45deg);z-index:2}
  .step:last-child::after{display:none}
  @media (max-width:900px){.steps{grid-auto-flow:row;grid-auto-columns:auto}.step{border-right:none;border-bottom:1px solid var(--line)}.step:last-child{border-bottom:none}.step::after{display:none}}

  /* DBS framework */
  .dbs{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:36px 0}
  .dbs .card{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:36px 32px}
  .dbs .card .l{font-family:var(--serif);font-size:80px;line-height:.85;color:var(--accent);font-weight:500;margin-bottom:14px}
  .dbs .card .name{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--ink-3);text-transform:uppercase;margin-bottom:10px}
  .dbs .card h5{font-family:var(--serif);font-size:20px;font-weight:500;margin:0 0 10px}
  .dbs .card p{margin:0;font-size:14px;line-height:1.7}
  @media (max-width:900px){.dbs{grid-template-columns:1fr}}

  /* code-ish block */
  .codeblock{background:#1B1A17;color:#F4F1EA;border-radius:14px;padding:22px 26px;font-family:var(--mono);font-size:13.5px;line-height:1.7;margin:24px 0;overflow:auto}
  .codeblock .c{color:#8A857B}
  .codeblock .k{color:#E8A47B}
  .codeblock .s{color:#B5C28A}

  /* use cases */
  .usecases{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:36px 0}
  .uc{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:32px;display:flex;flex-direction:column;gap:16px}
  .uc .ico{width:48px;height:48px;border-radius:12px;background:var(--accent);color:#fff;display:grid;place-items:center}
  .uc h5{font-family:var(--serif);font-size:20px;font-weight:500;margin:0;line-height:1.45;min-height:calc(20px * 1.45 * 2)}
  .uc p{margin:0;font-size:14px;line-height:1.7}
  .uc .meta{margin-top:auto;padding-top:14px;border-top:1px dashed var(--line-2);font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.08em;display:flex;justify-content:space-between}
  @media (max-width:900px){.usecases{grid-template-columns:1fr}}

  /* impact table */
  table.impact{table-layout:fixed}
  table.impact td.key{width:auto}
  table.impact th:nth-child(1),table.impact td:nth-child(1){width:40%}
  table.impact th:nth-child(2),table.impact td:nth-child(2){width:20%}
  table.impact th:nth-child(3),table.impact td:nth-child(3){width:20%}
  table.impact th:nth-child(4),table.impact td:nth-child(4){width:20%}
  table.impact td.before{color:var(--ink-3);font-family:var(--mono);font-size:14px}
  table.impact td.after{color:var(--accent);font-family:var(--mono);font-size:14px;font-weight:600}
  table.impact td.delta{text-align:right;font-family:var(--mono);font-size:13px;color:var(--leaf);font-weight:600}
  /* どこで Skills を使えるか: 利用環境=Skills機能 同幅、備考は狭める */
  table.envs{table-layout:fixed}
  table.envs td.key{width:auto;white-space:nowrap}
  table.envs th:nth-child(1),table.envs td:nth-child(1){width:25%}
  table.envs th:nth-child(2),table.envs td:nth-child(2){width:25%}
  table.envs th:nth-child(3),table.envs td:nth-child(3){width:50%}

  /* pitfalls */
  .pitfalls{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin:36px 0}
  .pit{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:28px 32px;display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:flex-start}
  .pit .n{font-family:var(--serif);font-size:36px;color:var(--accent);line-height:1;font-weight:500}
  .pit h5{font-family:var(--serif);font-size:18px;font-weight:500;margin:0 0 6px}
  .pit p{margin:0;font-size:13.5px;line-height:1.65;color:var(--ink-2)}
  @media (max-width:900px){.pitfalls{grid-template-columns:1fr}}

  /* checklist */
  .checklist{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:36px 40px;margin:32px 0}
  .checklist h5{font-family:var(--serif);font-size:20px;font-weight:500;margin:0 0 18px}
  .checklist ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px}
  .checklist li{display:flex;align-items:flex-start;gap:14px;font-size:14.5px;color:var(--ink-2);line-height:1.6}
  .checklist li .chk{width:22px;height:22px;border-radius:6px;background:var(--accent);color:#fff;display:grid;place-items:center;flex-shrink:0;margin-top:2px}

  /* CTA */
  .cta{background:var(--ink);color:#F4F1EA;border-radius:18px;padding:72px 64px;margin:80px 0 40px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center}
  .cta h3{font-family:var(--serif);font-size:36px;font-weight:500;line-height:1.3;margin:0 0 14px;color:#fff}
  .cta p{color:#C8C4BB;font-size:15.5px;margin:0;max-width:560px}
  .cta .btn{background:var(--accent);color:#fff;padding:18px 32px;border-radius:12px;font-weight:500;font-size:15px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;white-space:nowrap}
  .cta .btn:hover{background:var(--accent-2)}
  @media (max-width:900px){.cta{grid-template-columns:1fr;padding:44px 32px}}

  /* footer */
  footer{padding:48px 0;border-top:1px solid var(--line);font-size:12.5px;color:var(--ink-3);font-family:var(--mono);letter-spacing:.06em}
  footer .wrap{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}

  /* utility */
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:48px}
  @media (max-width:900px){.grid-2{grid-template-columns:1fr;gap:24px}}
  .small{font-size:13px;color:var(--ink-3)}
  hr.div{border:none;border-top:1px dashed var(--line-2);margin:48px 0}

  /* code inline accent (replaces scattered inline styles) */
  .code-inline-accent{font-family:var(--mono);background:var(--accent-soft);color:var(--accent-2);padding:2px 8px;border-radius:4px;font-size:13px}

  /* 用語集クロスリンク */
  a.gloss{color:inherit;text-decoration:none;border-bottom:1px dotted var(--accent);padding-bottom:1px;transition:background .2s ease, color .2s ease, border-color .2s ease}
  a.gloss:hover{background:var(--accent-soft);color:var(--accent-2);border-bottom-color:var(--accent-2)}
  a.gloss::after{content:"↗";font-size:.7em;margin-left:.15em;color:var(--accent);opacity:.65;vertical-align:super}
  tbody tr[id^="term-"]{transition:background .8s ease;scroll-margin-top:90px}
  tbody tr[id^="term-"]:target td{background:var(--accent-soft)}
  tbody tr[id^="term-"]:target td.key{color:var(--accent-2)}
  /* 戻るボタンはハイライト行の右側に固定表示（位置は JS が計算） */
  .return-btn{position:fixed;top:0;left:0;z-index:60;padding:10px 18px;border:1px solid var(--line-2);background:var(--paper);color:var(--ink);font-family:var(--sans);font-size:13px;font-weight:500;border-radius:999px;box-shadow:0 6px 20px rgba(27,26,23,.14);cursor:pointer;display:none;align-items:center;gap:6px;letter-spacing:.02em;transform:translateY(-50%);white-space:nowrap;transition:background .2s ease, color .2s ease, border-color .2s ease, box-shadow .2s ease}
  .return-btn:hover{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 8px 24px rgba(200,100,60,.32)}
  .return-btn.is-visible{display:inline-flex}
  @media (max-width:900px){.return-btn{top:auto!important;left:auto!important;bottom:16px;right:16px;transform:none;padding:11px 18px;font-size:12.5px}}
</style>
</head>
<body>

<!-- icon library (symbols) -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- common stroke icon style: 24x24, stroke-width 1.6, rounded -->
    <g id="ico-flag"><path d="M5 21V4M5 4h11l-2 4 2 4H5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-layers"><path d="M12 3l9 5-9 5-9-5 9-5zM3 13l9 5 9-5M3 18l9 5 9-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-filter"><path d="M4 5h16l-6 8v6l-4-2v-4L4 5z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-tool"><path d="M14 6a3.5 3.5 0 014.5 4.5L9 20l-4-4 9.5-9.5z M13 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-bank"><path d="M3 10L12 4l9 6M5 10v8M19 10v8M9 10v8M15 10v8M3 20h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-shield"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>

    <g id="ico-spark"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z M19 16l.8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-clock"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></g>
    <g id="ico-team"><circle cx="9" cy="9" r="3.2" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M3 20c0-3.5 2.7-6 6-6s6 2.5 6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/><circle cx="17" cy="8" r="2.6" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M15 14c4 0 6 2 6 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></g>
    <g id="ico-folder"><path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-arrow"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-alert"><path d="M12 3l10 18H2L12 3z M12 10v5 M12 18h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-lock"><rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M8 11V7a4 4 0 018 0v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></g>
    <g id="ico-target"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" fill="none"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6" fill="none"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></g>
    <g id="ico-book"><path d="M4 5a2 2 0 012-2h13v17H6a2 2 0 00-2 2V5z M9 3v17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-check"><path d="M5 12l5 5L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-doc"><path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z M14 3v5h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-bolt"><path d="M13 3L4 14h7l-1 7 9-11h-7l1-7z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-chart"><path d="M4 19V5 M4 19h16 M8 16l3-4 4 3 5-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-grid"><rect x="4" y="4" width="7" height="7" rx="1.4" stroke="currentColor" stroke-width="1.6" fill="none"/><rect x="13" y="4" width="7" height="7" rx="1.4" stroke="currentColor" stroke-width="1.6" fill="none"/><rect x="4" y="13" width="7" height="7" rx="1.4" stroke="currentColor" stroke-width="1.6" fill="none"/><rect x="13" y="13" width="7" height="7" rx="1.4" stroke="currentColor" stroke-width="1.6" fill="none"/></g>
    <g id="ico-search"><circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M16 16l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></g>
    <g id="ico-kitchen"><path d="M5 9c0-2.2 1.8-4 4-4 1 0 1.9.4 2.6 1 .7-.6 1.6-1 2.6-1 2.2 0 4 1.8 4 4v2H5V9z M5 11h14v8a2 2 0 01-2 2H7a2 2 0 01-2-2v-8z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-recipe"><path d="M7 4h10v16a1 1 0 01-1 1H8a1 1 0 01-1-1V4z M10 9h4 M10 13h4 M10 17h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></g>
    <g id="ico-route"><circle cx="6" cy="6" r="2.5" stroke="currentColor" stroke-width="1.6" fill="none"/><circle cx="18" cy="18" r="2.5" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M6 8.5V14a4 4 0 004 4h5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-cycle"><path d="M20 12a8 8 0 11-3-6.2 M20 4v4h-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
    <g id="ico-feather"><path d="M20 4c-7 0-12 5-12 12v4h4c7 0 12-5 12-12V4h-4z M4 20l9-9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></g>
  </defs>
</svg>

<nav class="nav">
  <div class="nav-inner">
    <div class="brand">
      <span class="brand-mark">{{> icon name=nav.brand_icon size=14}}</span>
      <span>{{nav.brand}}</span>
    </div>
    <div class="nav-links">
      {{#each nav.links}}
        <a href="{{href}}">{{label}}</a>
      {{/each}}
    </div>
  </div>
</nav>

<header class="hero">
  <div class="wrap">
    <span class="eyebrow"><span class="dot"></span>{{hero.eyebrow}}</span>
    <h1 class="display">{{{mdHead hero.headline_md}}}</h1>
    <p class="lede">{{hero.lede}}</p>

    <div class="hero-meta">
      {{#each hero.meta}}
        <span>{{> icon name=icon size=14}}{{label}}</span>
      {{/each}}
    </div>

    <div class="hero-figure">
      {{#each hero.figure}}
        <div>
          <div class="k">{{key}}</div>
          <div class="v">{{value}}<span class="u">{{unit}}</span></div>
          <div class="c">{{caption}}</div>
        </div>
      {{/each}}
    </div>
  </div>
</header>

{{#each sections}}
<section id="{{id}}">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-head-left">
        <div class="sec-num">{{num}}</div>
        <div class="sec-icon">{{> icon name=icon size=26}}</div>
      </div>
      <div class="sec-title-block">
        <h2 class="sec">{{{mdHead title_md}}}</h2>
        <div class="sec-sub">{{subtitle}}</div>
      </div>
    </div>

    {{#each blocks}}
      {{> (lookup . 'type') }}
    {{/each}}
  </div>
</section>
{{/each}}

<footer>
  <div class="wrap">
    <span>{{footer.left}}</span>
    <span>{{footer.right}}</span>
  </div>
</footer>


<button class="return-btn" id="returnBtn" aria-label="元の位置に戻る">← 元の位置に戻る</button>

<script>
(function(){
  const TERMS = [
    // 長い順 / 紛らわしい順に並べる（SKILL.md > Claude系 > 複合語 > 単語）
    {p: /SKILL\.md/g, id: "term-skill-md"},
    {p: /Claude Cowork/g, id: "term-claude-cowork"},
    {p: /Claude API/g, id: "term-claude-api"},
    {p: /Claude\.ai/g, id: "term-claude-ai"},
    {p: /プログレッシブ・ディスクロージャー(?:（Progressive Disclosure）)?/g, id: "term-progressive-disclosure"},
    {p: /DBS\s*フレームワーク/g, id: "term-dbs-framework"},
    {p: /kebab-case/g, id: "term-kebab-case"},
    {p: /Markdown/g, id: "term-markdown"},
    {p: /YAML/g, id: "term-yaml"},
    {p: /Workflow/g, id: "term-workflow"},
    {p: /フロントマター/g, id: "term-frontmatter"},
    {p: /references/g, id: "term-references"},
    {p: /scripts/g, id: "term-scripts"},
    {p: /assets/g, id: "term-assets"},
    {p: /Dispatch/g, id: "term-dispatch"},
    {p: /トリガー/g, id: "term-trigger"},
    {p: /コンテキスト/g, id: "term-context"},
    {p: /トークン/g, id: "term-token"},
    {p: /MCP/g, id: "term-mcp"},
    {p: /プラグイン/g, id: "term-plugin"},
    {p: /Projects/g, id: "term-projects"},
    {p: /Artifacts/g, id: "term-artifacts"},
    {p: /(?<![A-Za-z])Skills(?![A-Za-z])/g, id: "term-skills"},
  ];

  // リンク化済み用語を追跡
  const linked = new Set();

  // スキップすべき要素のタグ名
  const SKIP_TAGS = new Set(['CODE','PRE','A','SCRIPT','STYLE','STRONG']);

  // #glossary セクション内かどうかを判定
  function isInsideGlossary(node) {
    let el = node.parentElement;
    while (el) {
      if (el.id === 'glossary') return true;
      el = el.parentElement;
    }
    return false;
  }

  // テキストノードにマッチした用語を a.gloss でラップ（最初の1件のみ）
  function linkifyTextNode(textNode) {
    let text = textNode.nodeValue;
    let changed = false;
    let resultHTML = '';
    let cursor = 0;

    while (cursor < text.length) {
      let earliest = null;
      let earliestIndex = Infinity;

      for (const term of TERMS) {
        if (linked.has(term.id)) continue;
        const re = new RegExp(term.p.source, term.p.flags.replace('g',''));
        re.lastIndex = 0;
        const searchStr = text.slice(cursor);
        const m = re.exec(searchStr);
        if (m && (cursor + m.index) < earliestIndex) {
          earliestIndex = cursor + m.index;
          earliest = {term, match: m[0], index: cursor + m.index};
        }
      }

      if (!earliest) {
        resultHTML += escapeHTML(text.slice(cursor));
        cursor = text.length;
      } else {
        resultHTML += escapeHTML(text.slice(cursor, earliest.index));
        resultHTML += '<a class="gloss" href="#' + earliest.term.id + '">' + escapeHTML(earliest.match) + '</a>';
        linked.add(earliest.term.id);
        cursor = earliest.index + earliest.match.length;
        changed = true;
      }
    }

    if (changed) {
      const span = document.createElement('span');
      span.innerHTML = resultHTML;
      textNode.parentNode.insertBefore(span, textNode);
      textNode.parentNode.removeChild(textNode);
    }
  }

  function escapeHTML(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // DOMツリーを再帰的に走査してテキストノードをリンク化
  function walk(node) {
    if (node.nodeType === Node.TEXT_NODE) {
      if (node.parentElement && SKIP_TAGS.has(node.parentElement.tagName)) return;
      if (isInsideGlossary(node)) return;
      const parentTag = node.parentElement ? node.parentElement.tagName : '';
      if (parentTag === 'P' || parentTag === 'LI') {
        linkifyTextNode(node);
      }
      return;
    }
    if (node.nodeType === Node.ELEMENT_NODE) {
      if (SKIP_TAGS.has(node.tagName)) return;
      if (node.id === 'glossary') return;
      const children = Array.from(node.childNodes);
      for (const child of children) {
        walk(child);
      }
    }
  }

  // ページ読み込み後に実行
  document.addEventListener('DOMContentLoaded', function() {
    walk(document.body);
    setupReturnButton();
  });

  // 「元の位置に戻る」ボタンの制御
  function setupReturnButton() {
    const btn = document.getElementById('returnBtn');
    if (!btn) return;

    let trackingActive = false;

    function positionButton() {
      const hash = window.location.hash;
      if (!hash.startsWith('#term-')) return;
      const target = document.getElementById(hash.slice(1));
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const top = rect.top + rect.height / 2;
      let left = rect.right + 16;
      const maxLeft = window.innerWidth - btn.offsetWidth - 12;
      if (left > maxLeft) left = maxLeft;
      btn.style.top = top + 'px';
      btn.style.left = left + 'px';
    }

    function startTracking() {
      if (trackingActive) return;
      window.addEventListener('scroll', positionButton, {passive: true});
      window.addEventListener('resize', positionButton);
      trackingActive = true;
    }
    function stopTracking() {
      if (!trackingActive) return;
      window.removeEventListener('scroll', positionButton);
      window.removeEventListener('resize', positionButton);
      trackingActive = false;
    }

    function showButton() {
      btn.classList.add('is-visible');
      positionButton();
      startTracking();
    }
    function hideButton() {
      btn.classList.remove('is-visible');
      stopTracking();
    }

    document.body.addEventListener('click', function(e) {
      const link = e.target.closest('a.gloss');
      if (link) {
        sessionStorage.setItem('glossReturnY', String(window.scrollY));
      }
    });

    btn.addEventListener('click', function() {
      const y = sessionStorage.getItem('glossReturnY');
      if (y !== null) {
        window.scrollTo({top: parseInt(y, 10), behavior: 'smooth'});
        sessionStorage.removeItem('glossReturnY');
      }
      hideButton();
    });

    function checkHash() {
      const hash = window.location.hash;
      if (hash.startsWith('#term-')) {
        if (sessionStorage.getItem('glossReturnY') !== null) {
          setTimeout(showButton, 250);
        }
      } else {
        hideButton();
      }
    }

    window.addEventListener('hashchange', checkHash);
    checkHash();
  }
})();
</script>
</body>
</html>
